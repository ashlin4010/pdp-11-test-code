.ASECT
.=4000

DATA:
    .WORD 000000,000000
    .WORD 000000,000000

.=2000

START:
    MOV #DATA, R0       ; Load absolute address 2000 into R0
    CLR (R0)+
    CLR (R0)+
    CLR (R0)+
    CLR (R0)+
    MOV #DATA, R0       ; Load absolute address 2000 into R0
LOOP:
    FADD+ R0
    RESET                   ; Slows the computer down
    BR LOOP